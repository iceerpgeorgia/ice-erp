generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model AuditLog {
  id         BigInt   @id @default(autoincrement())
  created_at DateTime @default(now())
  table      String
  record_id  BigInt
  action     String
  user_email String?
  user_id    String?
  changes    Json?

  @@index([created_at(sort: Desc)])
  @@index([table, record_id])
  @@index([user_email])
}

model Session {
  id           String   @id
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model User {
  id                       String                     @id
  name                     String?
  email                    String?                    @unique
  emailVerified            DateTime?
  image                    String?
  role                     String                     @default("user")
  isAuthorized             Boolean                    @default(false)
  authorizedAt             DateTime?
  authorizedBy             String?
  paymentNotifications     Boolean                    @default(false) @map("payment_notifications")
  counteragentUuid         String?                    @map("counteragent_uuid") @db.Uuid
  Account                  Account[]
  PaymentNotificationToken PaymentNotificationToken[]
  Session                  Session[]
  UserPermission           UserPermission[]
  ProjectReportView        ProjectReportView[]
  UserNavFolder            UserNavFolder[]
  UserNavItem              UserNavItem[]

  @@index([isAuthorized])
  @@index([role])
}

model UserNavFolder {
  id        String        @id @default(cuid())
  userId    String
  name      String        @db.VarChar(100)
  icon      String        @default("Folder") @db.VarChar(50)
  sortOrder Int           @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @default(now()) @updatedAt
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  items     UserNavItem[]

  @@index([userId], map: "user_nav_folders_userid_idx")
  @@map("user_nav_folders")
}

model UserNavItem {
  id        String         @id @default(cuid())
  userId    String
  routeKey  String         @db.VarChar(255)
  icon      String?        @db.VarChar(50)
  folderId  String?
  sortOrder Int            @default(0)
  folder    UserNavFolder? @relation(fields: [folderId], references: [id], onUpdate: NoAction)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, routeKey])
  @@index([userId], map: "user_nav_items_userid_idx")
  @@map("user_nav_items")
}

model ProjectReportView {
  id        BigInt   @id @default(autoincrement())
  uuid      String   @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id")
  name      String   @db.VarChar(100)
  config    Json     @default("{}")
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId], map: "idx_project_report_views_user_id")
  @@map("project_report_views")
}

model Module {
  id            BigInt          @id @default(autoincrement())
  uuid          String          @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String          @db.VarChar(100)
  key           String          @unique @db.VarChar(100)
  description   String?
  icon          String?         @db.VarChar(50)
  route         String?         @db.VarChar(255)
  displayOrder  Int             @default(0) @map("display_order")
  isActive      Boolean         @default(true) @map("is_active")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  ModuleFeature ModuleFeature[]

  @@index([isActive])
}

model ModuleFeature {
  id             BigInt           @id @default(autoincrement())
  uuid           String           @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  moduleId       BigInt           @map("module_id")
  moduleUuid     String           @map("module_uuid") @db.Uuid
  name           String           @db.VarChar(100)
  key            String           @db.VarChar(100)
  description    String?
  featureType    String           @default("action") @map("feature_type") @db.VarChar(50)
  isActive       Boolean          @default(true) @map("is_active")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  module         Module           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  RolePermission RolePermission[]
  UserPermission UserPermission[]

  @@unique([moduleId, key])
  @@index([moduleId])
  @@index([moduleUuid])
  @@index([isActive])
}

model UserPermission {
  id                BigInt        @id @default(autoincrement())
  uuid              String        @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String        @map("user_id")
  moduleFeatureId   BigInt        @map("module_feature_id")
  moduleFeatureUuid String        @map("module_feature_uuid") @db.Uuid
  grantedBy         String?       @map("granted_by")
  grantedAt         DateTime      @default(now()) @map("granted_at")
  expiresAt         DateTime?     @map("expires_at")
  isActive          Boolean       @default(true) @map("is_active")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")
  moduleFeature     ModuleFeature @relation(fields: [moduleFeatureId], references: [id], onDelete: Cascade)
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleFeatureId])
  @@index([userId])
  @@index([moduleFeatureId])
  @@index([isActive])
  @@index([expiresAt])
}

model RolePermission {
  id                BigInt        @id @default(autoincrement())
  uuid              String        @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  role              String        @db.VarChar(50)
  moduleFeatureId   BigInt        @map("module_feature_id")
  moduleFeatureUuid String        @map("module_feature_uuid") @db.Uuid
  isActive          Boolean       @default(true) @map("is_active")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")
  moduleFeature     ModuleFeature @relation(fields: [moduleFeatureId], references: [id], onDelete: Cascade)

  @@unique([role, moduleFeatureId])
  @@index([role])
  @@index([moduleFeatureId])
  @@index([isActive])
}

model PaymentNotificationToken {
  id        BigInt    @id @default(autoincrement())
  uuid      String    @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  token     String    @unique
  userId    String    @map("user_id")
  paymentId String    @map("payment_id")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([paymentId])
  @@index([expiresAt])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model BankAccount {
  id                        BigInt                      @id @default(autoincrement())
  uuid                      String                      @unique @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  accountNumber             String                      @map("account_number")
  currencyUuid              String                      @map("currency_uuid") @db.Uuid
  isActive                  Boolean                     @default(true) @map("is_active")
  createdAt                 DateTime                    @default(now()) @map("created_at")
  updatedAt                 DateTime                    @updatedAt @map("updated_at")
  bankUuid                  String?                     @map("bank_uuid") @db.Uuid
  balance                   Decimal?                    @db.Decimal(18, 2)
  balanceDate               DateTime?                   @map("balance_date") @db.Date
  parsingSchemeUuid         String?                     @map("parsing_scheme_uuid") @db.Uuid
  rawTableName              String?                     @map("raw_table_name") @db.VarChar(255)
  parsingSchemeId           BigInt?                     @map("parsing_scheme_id")
  insiderUuid               String                      @map("insider_uuid") @db.Uuid
  bankAccountBalances       BankAccountBalance[]
  bank                      Bank?                       @relation(fields: [bankUuid], references: [uuid])
  currency                  currencies                  @relation(fields: [currencyUuid], references: [uuid])
  parsing_schemes           parsing_schemes?            @relation(fields: [parsingSchemeUuid], references: [uuid], onDelete: NoAction, onUpdate: NoAction)
  bog_gel_raw_statements    bog_gel_raw_statements[]
  raw_bank_statements       raw_bank_statements[]
  standardized_transactions standardized_transactions[]

  @@unique([accountNumber, currencyUuid])
  @@index([bankUuid])
  @@index([currencyUuid])
  @@index([parsingSchemeId])
  @@index([insiderUuid], map: "idx_bank_accounts_insider_uuid")
  @@map("bank_accounts")
}

model BankAccountBalance {
  id                    BigInt      @id @default(autoincrement())
  accountUuid           String      @map("account_uuid") @db.Uuid
  openingDate           DateTime    @map("opening_date") @db.Date
  openingBalance        Decimal     @map("opening_balance") @db.Decimal(20, 2)
  inflow                Decimal     @default(0) @db.Decimal(20, 2)
  outflow               Decimal     @default(0) @db.Decimal(20, 2)
  closingDate           DateTime    @map("closing_date") @db.Date
  closingBalance        Decimal?    @default(dbgenerated("((opening_balance + inflow) - outflow)")) @map("closing_balance") @db.Decimal(20, 2)
  openingBalanceBankApi Decimal?    @map("opening_balance_bank_api") @db.Decimal(20, 2)
  inflowBankApi         Decimal?    @map("inflow_bank_api") @db.Decimal(20, 2)
  outflowBankApi        Decimal?    @map("outflow_bank_api") @db.Decimal(20, 2)
  closingBalanceBankApi Decimal?    @map("closing_balance_bank_api") @db.Decimal(20, 2)
  bankAccount           BankAccount @relation(fields: [accountUuid], references: [uuid], onDelete: Cascade, onUpdate: NoAction)

  @@unique([accountUuid, openingDate], map: "uq_bank_account_balances_account_opening_date")
  @@index([accountUuid], map: "idx_bank_account_balances_account_uuid")
  @@index([openingDate], map: "idx_bank_account_balances_opening_date")
  @@index([closingDate], map: "idx_bank_account_balances_closing_date")
  @@map("bank_account_balances")
}

model Bank {
  id           BigInt        @id @default(autoincrement())
  uuid         String        @unique @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  bankName     String        @map("bank_name")
  isActive     Boolean       @default(true) @map("is_active")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  bankAccounts BankAccount[]

  @@map("banks")
}

