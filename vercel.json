{
  "buildCommand": "pnpm prisma generate && pnpm build",
  "installCommand": "pnpm install",
  "framework": "nextjs",
  "git": {
    "deploymentEnabled": false
  },
  "regions": ["iad1"],
  "env": {
    "NEXTAUTH_URL": "https://iceerpgeorgia.com"
  },
  "crons": [
    {
      "path": "/api/cron/bog-import-last-3-days",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/update-nbg-rates",
      "schedule": "0 16 * * *"
    },
    {
      "path": "/api/cron/cash-based-monthly-accruals",
      "schedule": "0 10 * * 0"
    },
    {
      "path": "/api/cron/recurring-payments-monthly",
      "schedule": "0 1 1 * *"
    }
  ]
}
