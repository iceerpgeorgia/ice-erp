# Copy to .env.local and fill values

# NextAuth (Google)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
NEXTAUTH_SECRET=your-random-secret
NEXTAUTH_URL=http://localhost:3000

# System Administrator Authorization
# Comma-separated list of Google email addresses that should be auto-authorized as system admins
AUTHORIZED_EMAILS=admin@example.com,sysadmin@example.com

# Postgres
# e.g. postgresql://user:password@localhost:5432/mydb?schema=public
DATABASE_URL=postgresql://postgres:fulebimojviT1985%25@localhost:5432/ICE_ERP?schema=public

# Supabase (optional integration)
# Project URL, anon key for browser, and service role for server-side tasks only
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Supabase designs table (optional; used by Figma)
SUPABASE_DESIGNS_TABLE=table_designs
SUPABASE_DESIGNS_SLUG_FIELD=slug
SUPABASE_DESIGNS_CONFIG_FIELD=config

# Figma design integration
FIGMA_FILE_KEY=Vky9Zd3NSzrdHFn02EG4dr
FIGMA_TOKEN=your-figma-personal-access-token
DESIGN_SOURCE=auto

# Cron Job Security
# Secret key for protecting cron endpoints (generate with: openssl rand -base64 32)
CRON_SECRET=your-random-secret-string-here

# Signify e-signature integration
# API docs: https://portal.signifyapp.com/api-documentation/docs/overview
SIGNIFY_BASE_URL=https://portal.signifyapp.com/integration-api/v2
SIGNIFY_CLIENT_ID=your-signify-client-id
SIGNIFY_CLIENT_SECRET=your-signify-client-secret
# Optional: protects internal trigger endpoint /api/integrations/signify/send
SIGNIFY_TRIGGER_SECRET=your-random-trigger-secret

# Bank of Georgia Business Online API integration
# Docs: https://api.bog.ge/docs/en/bonline/introduction
BOG_BASE_URL=https://api.businessonline.ge/api
BOG_TOKEN_URL=https://account.bog.ge/auth/realms/bog/protocol/openid-connect/token
# Preferred multi-insider credential format (JSON array)
# Example:
# BOG_CREDENTIALS_MAP=[{"insiderUuid":"2a55debb-261b-4ce9-bae4-296ddea037ab","clientId":"your-bog-client-id","clientSecret":"your-bog-client-secret"}]
BOG_CREDENTIALS_MAP=[]
# Legacy single-credential fallback (optional)
BOG_CLIENT_ID=
BOG_CLIENT_SECRET=
# Optional defaults to "corp"
BOG_SCOPE=corp
# Optional manual bearer token (useful for short-term testing)
BOG_ACCESS_TOKEN=
# Optional convenience path for statement endpoint probes (used in docs/examples)
BOG_STATEMENT_PATH=

